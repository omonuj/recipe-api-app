# Environment variables for production (set these in the Vercel dashboard).
# Locally / in Docker these are optional — see docker-compose.yml.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=0
ALLOWED_HOSTS=.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-project.vercel.app

# Database — a single connection URL to a managed PostgreSQL instance,
# e.g. Vercel Postgres, Neon, or Supabase.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# Local Docker alternative to DATABASE_URL (used only when DATABASE_URL is unset)
DB_HOST=db
DB_NAME=app
DB_USER=postgres
DB_PASS=supersecretpassword
